                                            @mouseleave="hoveredContactId = null"
                                            :style="hoveredContactId === item.id ? 'background:#f5faff;' : ''">
                                            <img :src="item.photo || item.avatar_url || attribute.user"
                                                class="contact-avatar" alt="Avatar" />
