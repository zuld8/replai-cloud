                                                <span class="visually-hidden">Loading...</span>
                                            </div>
                                        </div>
                                    </template>

                                    <!-- Empty State -->
                                    <div v-if="!modalContactsLoading && filteredModalContacts.length === 0"
                                        class="empty-state-modal">
                                        <i class='bx bx-user-x'></i>
                                        <p>{{ $t('contact.contact_not_found') }}</p>
