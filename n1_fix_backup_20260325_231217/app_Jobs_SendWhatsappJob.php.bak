<?php

namespace App\Jobs;

use App\Models\Blash\BlashDetail;
use App\Models\Blash\BlashWhatsapp;
use App\Models\Store\Store;
use App\Models\WhatsappDevice;
use App\Models\WhatsappKeyAccount;
use App\Services\Sistem\QueueRouter;
use Carbon\Carbon;
use Illuminate\Contracts\Queue\ShouldQueue;
use Illuminate\Foundation\Queue\Queueable;
use Illuminate\Support\Facades\Cache;
use Illuminate\Support\Facades\Log;
use Exception;

class SendWhatsappJob implements ShouldQueue
{
    use Queueable;


    /**
     * Job timeout in seconds
     */
    public $timeout = 300;

    /**
     * Maximum number of attempts
     */
    public $tries = 1; // No retry - process once only

    public function __construct()
    {
        //
    }

    public function handle(): void
    {
        try {
            $schedules = BlashWhatsapp::where("use", "whatsapp")
                ->where("status", "pending")
                ->where("schedule", "<=", now())
                ->orderBy('created_at', 'asc')
                ->get();

            foreach ($schedules as $schedulingPromotions) {
                try {
                    $this->processBatchBroadcast($schedulingPromotions);
                } catch (Exception $e) {
                    Log::error("Error processing schedule {$schedulingPromotions->id}: " . $e->getMessage());
                    // Continue with next schedule instead of failing entire job
                    continue;
                }
            }
        } catch (Exception $e) {
            Log::error("SendWhatsappJob failed: " . $e->getMessage());
            // Don't throw - prevent retry loop
        }
    }

    private function processBatchBroadcast($schedulingPromotions)
    {
        // ATOMIC LOCK: Prevent concurrent processing of same broadcast
        $lockKey = "broadcast:creating:{$schedulingPromotions->id}";
        $lock = Cache::lock($lockKey, 600); // 10 min lock
        
        if (!$lock->get()) {
            Log::info("SendWhatsappJob: Broadcast {$schedulingPromotions->id} already being processed by another worker, skipping");
            return;
        }
        
        try {
            $this->doProcessBatchBroadcast($schedulingPromotions);
        } finally {
            $lock->forceRelease();
        }
    }

    private function doProcessBatchBroadcast($schedulingPromotions)
    {
        $delay = $schedulingPromotions->delay ?? 5;
        $stopSending = $schedulingPromotions->stop_sending ?? 20;
        $restSending = $schedulingPromotions->rest_sending ?? 90;

        // Get target stores
        $getStores = Store::where(function ($q) use ($schedulingPromotions) {
            return $schedulingPromotions->category_id != null ?
                $q->where("category_id", $schedulingPromotions->category_id) : '';
        })->where(function ($q) use ($schedulingPromotions) {
            return $schedulingPromotions->group_whatsapp_id != null ?
                $q->where("whatsapp_group_id", $schedulingPromotions->group_whatsapp_id) : '';
        })->where(function ($q) use ($schedulingPromotions) {
            return $schedulingPromotions->district_id != null ?
                $q->where("district_id", $schedulingPromotions->district_id) : '';
        })->where(function ($q) use ($schedulingPromotions) {
            return $schedulingPromotions->city_id != null ?
                $q->whereHas("district", function ($q) use ($schedulingPromotions) {
                    return $q->where("city_id", $schedulingPromotions->city_id);
                }) : '';
        })->where("phone", "!=", null)
            ->where("status", "no")
            ->orderBy('name', 'asc')
            ->get();

        if ($getStores->isEmpty()) {
            // Check if all blash_details are already sent
            $unsent = BlashDetail::where('blash_whatsapp_id', $schedulingPromotions->id)
                ->where('status', 'no')->count();
            if ($unsent == 0) {
                $schedulingPromotions->update(['status' => 'success']);
            } else {
                Log::warning("Broadcast {$schedulingPromotions->id}: no stores found but {$unsent} details unsent. Keeping pending.");
            }
            return;
        }

        // Get available devices
        $availableDevices = $this->getAvailableDevices($schedulingPromotions);

        if ($availableDevices->isEmpty()) {
            Log::warning("Broadcast {$schedulingPromotions->id} ({$schedulingPromotions->name}): no available devices. Waba={$schedulingPromotions->waba}, Devices={$schedulingPromotions->devices}");
            return;
        }


        // Distribute stores to devices (round-robin)
        $deviceGroups = $this->distributeStores($getStores, $availableDevices);

        // Schedule BATCH messages for each device group
        $totalBatches = 0;
        foreach ($deviceGroups as $deviceId => $stores) {
            $batches = $this->scheduleBatchMessages($deviceId, $stores, $schedulingPromotions, $delay, $stopSending, $restSending);
            $totalBatches += $batches;
        }


        // Verify all details have been dispatched
        $totalDetails = BlashDetail::where('blash_whatsapp_id', $schedulingPromotions->id)->count();
        $unsentDetails = BlashDetail::where('blash_whatsapp_id', $schedulingPromotions->id)
            ->where('status', 'no')
            ->where('sending_status', '!=', 'yes')
            ->count();

        if ($totalBatches > 0) {
            Log::info("Broadcast {$schedulingPromotions->id}: dispatched {$totalBatches} batches for {$totalDetails} contacts, {$unsentDetails} still unsent");
            // Don't mark success yet — let RedispatchStuckBroadcasts verify all sent
            $schedulingPromotions->update(['status' => 'processing']);
        } else {
            // No batches dispatched — keep pending for retry
            Log::warning("Broadcast {$schedulingPromotions->id}: 0 batches dispatched! Keeping pending for retry.");
            $schedulingPromotions->update(['status' => 'pending']);
        }
    }

    private function getAvailableDevices($schedulingPromotions)
    {
        $wabaOfficial = $schedulingPromotions->waba ?? 'no';

        if ($wabaOfficial == 'yes') {
            $query = WhatsappKeyAccount::where(function ($q) {
                return $q->whereRaw('daily_send < limit_per_day')->orWhere("daily_limit", "no");
            })->where("status", "active");
        } else {
            $query = WhatsappDevice::where(function ($q) {
                return $q->whereRaw('daily_send < limit_per_day')->orWhere("daily_limit", "no");
            })->where("business_id", $schedulingPromotions->business_id)
                ->where("status", "active");
        }

        // Filter by selected devices
        if ($schedulingPromotions->devices != null) {
            $deviceIds = explode(',', $schedulingPromotions->devices);
            $query->whereIn('id', $deviceIds);
        }

        return $query->get();
    }

    private function distributeStores($stores, $devices)
    {
        $deviceGroups = [];
        $deviceIds = $devices->pluck('id')->toArray();

        foreach ($stores as $index => $store) {
            $deviceIndex = $index % count($deviceIds);
            $deviceId = $deviceIds[$deviceIndex];

            if (!isset($deviceGroups[$deviceId])) {
                $deviceGroups[$deviceId] = [];
            }

            $deviceGroups[$deviceId][] = $store;
        }

        return $deviceGroups;
    }

    /**
     * Schedule BATCH messages instead of individual
     * Returns number of batches created
     */
    private function scheduleBatchMessages($deviceId, $stores, $schedulingPromotions, $delay, $stopSending, $restSending): int
    {
        // Define batch size (100 kontak per batch)
        $batchSize = 100;
        $batches = collect($stores)->chunk($batchSize);

        // Get last schedule for this device
        $lastSchedule = $this->getLastDeviceSchedule($deviceId, $schedulingPromotions->business_id);
        $currentTime = $lastSchedule ?: now();

        $batchCount = 0;

        foreach ($batches as $batchIndex => $batchStores) {
            $blastIds = [];
            $batchStartTime = clone $currentTime;

            // Create BlashDetail records for this batch
            foreach ($batchStores as $localIndex => $store) {
                $globalIndex = ($batchIndex * $batchSize) + $localIndex;

                // Calculate rest time based on global index
                $restTimeOffset = 0;
                if ($stopSending > 0 && $globalIndex > 0) {
                    $restCycles = floor($globalIndex / $stopSending);
                    $restTimeOffset = $restCycles * $restSending;
                }

                // Schedule time for this specific message
                $messageScheduleTime = (clone $batchStartTime)->addSeconds(($localIndex * $delay) + $restTimeOffset);

                // DEDUP: Skip if phone already exists for this broadcast
                // Use DB-level check + firstOrCreate by PHONE (not store_id)
                $message = BlashDetail::firstOrCreate(
                    [
                        'blash_whatsapp_id' => $schedulingPromotions->id,
                        'phone' => $store->phone,  // Dedup by phone, NOT store_id
                    ],
                    [
                        'store_id' => $store->id,
                        'status' => 'no',
                        'sending_status' => 'no',
                        'delivery_status' => null,
                        'schedule' => $messageScheduleTime->format('Y-m-d H:i:s'),
                        'device_id' => $deviceId
                    ]
                );

                // If this was NOT newly created, skip (already exists)
                if (!$message->wasRecentlyCreated) {
                    continue;
                }

                $blastIds[] = $message->id;
            }

            // Calculate when this batch should start executing
            $isWabaBroadcast = ($schedulingPromotions->waba ?? 'no') === 'yes';
            
            if ($isWabaBroadcast) {
                // WABA: dispatch immediately, no staggered delays needed
                $batchDelay = 0;
            } else {
                // WA Biasa: keep staggered delay to prevent ban
                $batchDelay = $batchStartTime->greaterThan(now()) ?
                    $batchStartTime->diffInSeconds(now()) : 0;
            }

            // Dispatch SINGLE batch job with all IDs
            $queue = QueueRouter::getQueue($schedulingPromotions->business_id, 'broadcast');
            Log::info("Business ID: {$schedulingPromotions->business_id}, Queue: {$queue}, WABA: " . ($isWabaBroadcast ? 'YES-FAST' : 'NO'));

            if ($isWabaBroadcast) {
                // WABA: dispatch immediately without delay
                dispatch(new SendPromotionWhatsappBatchJob($blastIds, $delay, $stopSending, $restSending))
                    ->onQueue($queue);
            } else {
                // WA Biasa: dispatch with calculated delay
                dispatch(new SendPromotionWhatsappBatchJob($blastIds, $delay, $stopSending, $restSending))
                    ->onQueue($queue)
                    ->delay(now()->addSeconds($batchDelay));
            }

            $batchCount++;

            // Update currentTime for next batch
            $lastMessageIndex = ($batchIndex * $batchSize) + ($batchStores->count() - 1);
            $restCycles = $stopSending > 0 ? floor($lastMessageIndex / $stopSending) : 0;
            $totalRestTime = $restCycles * $restSending;
            $currentTime = (clone $batchStartTime)->addSeconds((($batchStores->count() - 1) * $delay) + $totalRestTime);
        }

        // Cache last schedule for this device
        $cacheKey = "last_device_schedule_{$deviceId}_{$schedulingPromotions->business_id}";
        Cache::put($cacheKey, $currentTime, now()->addHours(24));

        return $batchCount;
    }

    private function getLastDeviceSchedule($deviceId, $businessId)
    {
        // Check cache first
        $cacheKey = "last_device_schedule_{$deviceId}_{$businessId}";
        $cached = Cache::get($cacheKey);

        if ($cached) {
            return Carbon::parse($cached);
        }

        // Check database
        $lastSchedule = BlashDetail::where("status", "no")
            ->where("device_id", $deviceId)
            ->whereHas('parent', function ($q) use ($businessId) {
                return $q->where("use", 'whatsapp')
                    ->where('business_id', $businessId);
            })
            ->orderBy('schedule', 'desc')
            ->first(['schedule']);

        if ($lastSchedule && $lastSchedule->schedule) {
            $parsed = Carbon::parse($lastSchedule->schedule);
            if ($parsed->greaterThan(now())) {
                return $parsed;
            }
        }

        return now();
    }

    /**
     * Handle failed job
     */
    public function failed(Exception $exception): void
    {
        Log::error("SendWhatsappJob permanently failed: " . $exception->getMessage());
    }
}