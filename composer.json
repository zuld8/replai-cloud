{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "algolia/algoliasearch-client-php": "^3.4",
        "google/apiclient": "^2.18",
        "google/apiclient-services": "^0.403.0",
        "guzzlehttp/guzzle": "^7.9",
        "intervention/image": "^2.7",
        "laravel/framework": "^11.9",
        "laravel/horizon": "^5.40",
        "laravel/reverb": "^1.0",
        "laravel/scout": "^10.11",
        "laravel/socialite": "^5.21",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.5",
        "laravolt/avatar": "^5.1",
        "maatwebsite/excel": "^3.1",
        "phpmailer/phpmailer": "^6.9",
        "phpoffice/phpspreadsheet": "^1.30",
        "phpoffice/phpword": "^1.3",
        "predis/predis": "^3.3",
        "simplehtmldom/simplehtmldom": "dev-master",
        "smalot/pdfparser": "^2.12",
        "spatie/laravel-permission": "^6.23",
        "spatie/laravel-sluggable": "^3.6",
        "symfony/css-selector": "^7.1",
        "symfony/dom-crawler": "^7.1",
        "wisembly/elephant.io": "^2.0",
        "yajra/laravel-datatables-oracle": "^11.1"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16",
        "dbrekelmans/bdi": "^1.3",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mdh-digital/mdh-license": "dev-master",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0.1",
        "symfony/panther": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": ["app/Helper/Helper.php","app/Helper/OpenAiPrompt.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
