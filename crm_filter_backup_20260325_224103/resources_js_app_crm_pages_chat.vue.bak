    font-size: 14px;
    color: #1f2937;
    position: sticky;
    top: 0;
    background: white;
    z-index: 1;
}

.template-panel-header span {
    display: flex;
    align-items: center;
    gap: 8px;
}

.template-close, .template-back {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 20px;
    color: #6b7280;
    padding: 2px;
    border-radius: 4px;
}

.template-close:hover, .template-back:hover {
    color: #374151;
    background: #f3f4f6;
}

.template-search {
    padding: 8px 16px;
    border-bottom: 1px solid #f3f4f6;
    position: sticky;
