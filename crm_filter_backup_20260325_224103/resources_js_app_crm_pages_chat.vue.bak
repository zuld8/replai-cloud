    background: white;
    border-radius: 12px 12px 0 0;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
    max-height: 420px;
    overflow-y: auto;
    z-index: 999;
    animation: slideUp 0.2s ease;
}

