<?php

namespace App\Http\Resources\Crm;

use Illuminate\Http\Request;
use Illuminate\Http\Resources\Json\JsonResource;

class ContactDetailResource extends JsonResource
{
    /**
     * Transform the resource into an array.
     *
     * @return array<string, mixed>
     */
    public function toArray(Request $request): array
    {

        $dviceId = null;
        if ($this->from == 'livechat') {
            $dviceId   = $this->livechat_id;
        }

        if ($this->from == 'telegram') {
            $dviceId   = $this->telegram_id;
        }

        if ($this->from == 'waba') {
            $dviceId   = $this->whatsapp_waba_id;
        }

        if ($this->from == 'whatsapp') {
            $dviceId   = $this->device_id;
        }

        return [
            'id'            => $this->id,
            'name'          => $this->name,
            'phone'         => $this->from_number,
            'status'        => $this->status,
            'from'          => $this->from,
            'device'        => $this->device->name ?? '',
            'livechat'      => $this->livechat->name ?? '',
            'device_id'     => $dviceId,
            'label'         => json_decode($this->label ?? '[]', true),
            'collabolators' => json_decode($this->collabolator ?? '[]', true),
            'additional'    => array(
                'data'          => json_decode($this->additional_data ?? '[]', true),
                'note'          => $this->note
            ),
            'takeover'      => $this->takeover == 'yes' ? true : false,
            'handled'       => array(
                'id'            => $this->handled->id ?? '',
                'name'          => $this->handled->name ?? ''
            ),
            'category'      => array(
                'id'            => $this->store->category->id ?? '',
                'name'          => $this->store->category->name ?? ''
            ),
            'pipeline'      => array(
                'id'            => $this->store->label->pipeline->id ?? null,
                'name'          => $this->store->label->pipeline->name ?? null,
                'stage'         => array(
                    'id'            => $this->store->label->id ?? null,
                    'name'          => $this->store->label->name ?? null,
                )
            ),
            'photo'         => $this->image_data,
            'last_incoming_at'  => $this->lastIncomingMessage ? $this->lastIncomingMessage->created_at->toIso8601String() : null,
            'detail'        => array(
                'assignment_by'     => $this->assignmentby->name ?? '',
                'resolved_by'       => $this->resolved->name ?? '',
                'ai'                => $this->livechat->finetunnel->name ?? '',
                'assignment_at'     => $this->assignment_at != null ? $this->assignment_at->format('Y-m-d H:i') : '',
                'resolved_at'       => $this->resolved_at != null ? $this->resolved_at->format('Y-m-d H:i') : '',
                'created_at'        => $this->created_at->format('Y-m-d H:i')
            )
        ];
    }
}
