    public function __construct(
        HistoryChatObserver $historyChatObserver,
        LabelObserver $labelObserver,
        UserObserver $userObserver,
        WhatsappServiceObserver $whatsappServiceObserver,
        CategoryObserver $categoryObserver,
        WhatsappOfficialServiceObserver $whatsappOfficialServiceObserver,
        TelegramService $telegramService,
        WhatsappDeviceObserver $whatsappDeviceObserver,
        LiveChatObserver $livechatObserver,
        WhatsappOfficialObserver $wabaDeviceObserver,
        StoreObserver $storeObserver,
        InstagramService $instagramService,
        MesaangerService $messengerService
    ) {
        $this->historyChatObserver              = $historyChatObserver;
        $this->labelObserver                    = $labelObserver;
        $this->userObserver                     = $userObserver;
        $this->whatsappServiceObserver          = $whatsappServiceObserver;
        $this->categoryObserver                 = $categoryObserver;
        $this->whatsappOfficialServiceObserver  = $whatsappOfficialServiceObserver;
        $this->telegramService                  = $telegramService;
        $this->whatsappDeviceObserver           = $whatsappDeviceObserver;
        $this->livechatObserver                 = $livechatObserver;
        $this->wabaDeviceObserver               = $wabaDeviceObserver;
        $this->storeObserver                    = $storeObserver;
        $this->instagramService                 = $instagramService;
        $this->messengerService                 = $messengerService;
    }

    public function index()
    {
        return view('crm', ['page'       => 'Crm Manager']);
    }

    public function getContacts(Request $request)
    {
        $limit  = $request->limit ?: 10;
        $page   = (int)($request->page ?? 1);
        $data   = $this->historyChatObserver->getData($request);

        $bizId    = my_business();
        $userId   = my_user()->id;
        $tab      = $request->tab ?? 'all';
        $cacheKey = "crm_count_{$bizId}_{$userId}_{$tab}";

        $withRelations = [
            'last_message:id,history_chat_id,message,created_at,type',
            'device:id,name',
            'waba:id,phone',
            'livechat:id,name',
            'telegram:id,name',
        ];

        if ($page === 1) {
            // Page 1: full paginate (needs COUNT for total display)
            // Cache the COUNT result for 30s - it runs once then served from Redis
            $contacts = $data->with($withRelations)->paginate($limit);
            $total    = Cache::remember($cacheKey, 30, fn() => $contacts->total());
        } else {
            // Page 2+: infinite scroll - SKIP the expensive COUNT(*) query entirely!
            // Use simplePaginate: only runs SELECT, no COUNT → ~2s saved per scroll
            // Frontend uses newContacts.length > 0 for hasMoreChats - doesn't need total
            $contacts = $data->with($withRelations)->simplePaginate($limit);
            // Return cached total (from page 1 load) so totalchats badge stays correct
            $total    = Cache::get($cacheKey, 0);
        }

        return response()->json([
            'total'       => $total,
            'merchant_id' => my_user()->merchant_id,
            'contacts'    => ContactListResource::collection($contacts),
        ], 200);
    }

    public function getStores(Request $request)
    {

        $limit      = $request->limit ? $request->limit : 10;
        $data       = $this->storeObserver->getData($request);

        $totalRows      = $data->count();
        $contacts       = $data->paginate($limit);

        return response()->json([
            'total'         => $contacts->total(),
            'merchant_id'   => my_user()->merchant_id,
            'contacts'      => StoreResource::collection($contacts),
        ], 200);
    }

    public function newChats(Request $request)
    {
        $request->validate([
            'name'      => 'required|string|max:255',
            'phone'     => 'required|string|max:30',
            'type'      => 'required|in:whatsapp,waba,livechat,telegram,instagram,messanger',
            'device_id' => 'nullable|string',
            'store_id'  => 'nullable|exists:stores,id'
        ]);

        // ✅ Auto-select atau validate device
        $deviceResult = $this->getAvailableDevice(
            $request->type,
            $request->device_id
        );

        if (!$deviceResult['success']) {
            return response()->json([
                'message' => $deviceResult['message'],
                'error' => 'NO_DEVICE_ACCESS'
            ], 403);
        }

        $deviceId = $deviceResult['device_id'];
        $autoSelected = $deviceResult['auto_selected'] ?? false;

        DB::beginTransaction();

        try {
            $businessId = my_business();
            $merchantId = my_user()->merchant_id;

            // Create/get store
            if ($request->store_id) {
                $store = Store::where('id', $request->store_id)->firstOrFail();
            } else {
                $store = Store::firstOrCreate(
                    [
                        'phone'         => $request->phone,
                        'business_id'   => $businessId
                    ],
                    [
                        'name' => $request->name,
                        'jid_number' => $request->phone . '@s.whatsapp.net',
                        'merchant_id' => $merchantId,
                        'avatar_url' => 'https://ui-avatars.com/api/?name=' . urlencode($request->name) . '&background=random&color=fff&size=128'
                    ]
                );
            }

            // Check existing conversation dengan device yang sesuai
            $existing = HistoryChat::where('store_id', $store->id)
                ->where('business_id', $businessId)
                ->where('from', $request->type)
                ->where(function ($q) use ($request, $deviceId) {
                    switch ($request->type) {
                        case 'waba':
                            $q->where('whatsapp_waba_id', $deviceId);
                            break;
                        case 'whatsapp':
                            $q->where('device_id', $deviceId);
                            break;
                        case 'livechat':
                            $q->where('livechat_id', $deviceId);
                            break;
                        case 'telegram':
                            $q->where('telegram_id', $deviceId);
                            break;
                        case 'instagram':
                            $q->where('instagram_id', $deviceId);
                            break;
                        case 'messanger':
                            $q->where('messanger_id', $deviceId);
                            break;
                    }
                })->first();

            if ($existing) {
                DB::commit();

                $response = [
                    'message' => 'Percakapan sudah ada',
                    'contact' => ContactDetailResource::make($existing),
                    'store' => $store
                ];

                if ($autoSelected) {
                    $response['device_auto_selected'] = true;
                    $response['device_name'] = $deviceResult['device_name'] ?? null;
                }

                return response()->json($response, 200);
            }

            // Create new conversation
            $historyData = [
                'store_id'          => $store->id,
                'name'              => $request->name,
                'from_number'       => $request->phone,
                'from'              => $request->type,
                'status'            => 'open',
                'type'              => 'inbox',
                'takeover'          => 'yes',
                'jid_number'        => $request->phone . '@s.whatsapp.net',
                'avatar_url'        => $store->avatar_url ?? 'https://ui-avatars.com/api/?name=' . urlencode($request->name) . '&background=random&color=fff&size=128',
                'merchant_id'       => $merchantId,
                'business_id'       => $businessId
            ];

            // Set device_id berdasarkan type
            switch ($request->type) {
                case 'waba':
                    $historyData['whatsapp_waba_id'] = $deviceId;
                    break;
                case 'whatsapp':
                    $historyData['device_id'] = $deviceId;
                    break;
                case 'livechat':
                    $historyData['livechat_id'] = $deviceId;
                    break;
                case 'telegram':
                    $historyData['telegram_id'] = $deviceId;
                    break;
                case 'instagram':
                    $historyData['instagram_id'] = $deviceId;
                    break;
                case 'messanger':
                    $historyData['messanger_id'] = $deviceId;
                    break;
            }

            $history = HistoryChat::create($historyData);

            DB::commit();

            $response = [
                'message' => 'Percakapan berhasil dibuat',
                'contact' => ContactDetailResource::make($history),
                'store' => $store
            ];

            if ($autoSelected) {
                $response['device_auto_selected'] = true;
                $response['device_name'] = $deviceResult['device_name'] ?? null;
            }

            return response()->json($response, 201);
        } catch (\Exception $e) {
            DB::rollBack();
            return response()->json([
                'message' => 'Gagal membuat percakapan',
                'error' => $e->getMessage(),
            ], 500);
        }
    }

    private function getAvailableDevice($type, $deviceId = null)
    {
        $userId = my_user()->id;

        // Jika device_id sudah ada, validasi apakah user punya akses
        if ($deviceId) {
            $hasAccess = $this->validateDeviceAccess($deviceId, $type, $userId);

            if (!$hasAccess) {
                return [
                    'success' => false,
                    'message' => 'Anda tidak memiliki akses ke device ini'
                ];
            }

            return [
                'success' => true,
                'device_id' => $deviceId
            ];
        }

        // Auto-select device yang user punya akses
        $device = $this->findDeviceByUserAccess($type, $userId);

        if (!$device) {
            return [
                'success' => false,
                'message' => 'Tidak ada perangkat ' . $this->getTypeName($type) . ' yang dapat diakses'
            ];
        }

        return [
            'success' => true,
            'device_id' => $device->id,
            'device_name' => $device->name ?? $device->phone ?? 'Device',
            'auto_selected' => true
        ];
    }

 private function findDeviceByUserAccess($type, $userId)
    {
        switch ($type) {
            case 'whatsapp':
                return WhatsappDevice::whereHas('agents', function ($q) use ($userId) {
                    $q->where('user_id', $userId);
                })
                    ->where('status', 'active')
                    ->orderBy('created_at', 'desc')
                    ->first(['id', 'name', 'phone']);

            case 'waba':
                return WhatsappKeyAccount::whereHas('agents', function ($q) use ($userId) {
                    $q->where('user_id', $userId);
                })
                    ->where('status', 'active')
                    ->orderBy('created_at', 'desc')
                    ->first(['id', 'phone']);

            case 'livechat':
                return LiveChat::whereHas('agents', function ($q) use ($userId) {
                    $q->where('user_id', $userId);
                })
                    ->orderBy('created_at', 'desc')
                    ->first(['id', 'name']);

            case 'telegram':
                return TelegramKey::whereHas('agents', function ($q) use ($userId) {
                    $q->where('user_id', $userId);
                })
                    ->orderBy('created_at', 'desc')
                    ->first(['id', 'name']);

            case 'instagram':
                return InstagramAccount::whereHas('agents', function ($q) use ($userId) {
                    $q->where('user_id', $userId);
                })
                    ->orderBy('created_at', 'desc')
                    ->first(['id', 'name']);

            case 'messanger':
                return MessengerAccount::whereHas('agents', function ($q) use ($userId) {
                    $q->where('user_id', $userId);
                })
                    ->orderBy('created_at', 'desc')
                    ->first(['id', 'page_name']);

            default:
                return null;
        }
    }

    private function validateDeviceAccess($deviceId, $type, $userId)
    {
        switch ($type) {
            case 'whatsapp':
                return WhatsappDevice::where('id', $deviceId)
                    ->whereHas('agents', function ($q) use ($userId) {
                        $q->where('user_id', $userId);
                    })
                    ->exists();

            case 'waba':
                return WhatsappKeyAccount::where('id', $deviceId)
                    ->whereHas('agents', function ($q) use ($userId) {
                        $q->where('user_id', $userId);
                    })
                    ->exists();

            case 'livechat':
                return LiveChat::where('id', $deviceId)
                    ->whereHas('agents', function ($q) use ($userId) {
                        $q->where('user_id', $userId);
                    })
                    ->exists();

            case 'telegram':
                return TelegramKey::where('id', $deviceId)
                    ->whereHas('agents', function ($q) use ($userId) {
                        $q->where('user_id', $userId);
                    })
                    ->exists();

            case 'instagram':
                return  InstagramAccount::where('id', $deviceId)
                    ->whereHas('agents', function ($q) use ($userId) {
                        $q->where('user_id', $userId);
                    })
                    ->exists();

            case 'messanger':
                return MessengerAccount::where('id', $deviceId)
                    ->whereHas('agents', function ($q) use ($userId) {
                        $q->where('user_id', $userId);
                    })
                    ->exists();

            default:
                return false;
        }
    }

    /**
     * ✅ Get friendly type name
     */
    private function getTypeName($type)
    {
        $names = [
            'whatsapp' => 'WhatsApp',
            'waba' => 'WhatsApp Business API',
            'livechat' => 'LiveChat',
            'telegram' => 'Telegram',
            'instagram' => 'Instagram',
            'messanger' => 'Messenger',
        ];

        return $names[$type] ?? $type;
    }



    public function getMessages(Request $request, HistoryChat $history)
    {
        $limit = $request->limit ?: 20;
        $page  = (int)($request->page ?? 1);
        $data  = $this->historyChatObserver->getMessage($request, $history->id);

        if ($page === 1) {
            // Page 1: full paginate to get total message count for UI
            $paginator = $data->paginate($limit);
            $totalRows = $paginator->total();
            $messages  = $paginator->getCollection()->sortBy('created_at')->values();
        } else {
            // Page 2+: SKIP COUNT on 1.69M rows — use simplePaginate
            // Frontend only needs message list + hasMore flag, not exact total
            $paginator = $data->simplePaginate($limit);
            $totalRows = null; // frontend keeps previous total
            $messages  = collect($paginator->items())->sortBy('created_at')->values();
        }

        return response()->json([
            'total'    => $totalRows,
            'messages' => MessagestResource::collection($messages),
        ], 200);
    }

    public function contactInformation(HistoryChat $history)
    {
        // FIX 2: Eager load semua relasi sekaligus, mencegah 8-12 lazy query
        $history->load([
            'device',
            'livechat.finetunnel',
            'store.category',
            'store.label.pipeline',
            'assignmentby',
            'resolved',
            'handled',
            'lastIncomingMessage',
        ]);
        return response()->json(ContactDetailResource::make($history), 200);
    }

    public function takeOfferChat(Request $request, HistoryChat $history)
    {
        $history->update([
            'assigned_by'       => $history->takeover == 'no' ? my_user()->id : $history->assigned_by,
            'assignment_at'     => $history->takeover == 'no' ? now() : $history->assignment_at,
            'handled_by'        => $history->takeover == 'no' ? my_user()->id : $history->handled_by,
            'takeover'          => $request->takeover == true ? 'yes' : 'no'
        ]);

        return response()->json([
            'handled'       => array(
                'id'            => $history->handled->id ?? '',
                'name'          => $history->handled->name ?? ''
            ),
            'detail'        => array(
                'assignment_by'     => $history->assignmentby->name ?? '',
                'assignment_at'     => $history->assignment_at != null ? $history->assignment_at->format('Y-m-d H:i') : '',
            ),
            'status'     => $request->takeover,
        ], 200);
    }

    public function sendMessage(Request $request, HistoryChat $history)
    {
        $this->validate($request, [
            'type'          => 'required|in:text,video,audio,document,image,media'
        ]);

        $messageType = 'text';
        $image  = array(
            'status'    => false,
            'type'      => null,
            'size'      => null,
            'path'      => null
        );

        $typeMap = [
            'image'    => ['image/jpeg', 'image/png', 'image/gif', 'image/webp'],
            'video'    => ['video/mp4', 'video/ogg', 'video/webm'],
            'audio'    => ['audio/mpeg', 'audio/wav', 'audio/ogg'],
            'document' => [
                'application/pdf',
                'application/zip',
                'application/octet-stream',
                'application/msword',
                'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
                'application/vnd.ms-excel',
                'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
                'application/vnd.ms-powerpoint',
                'application/vnd.openxmlformats-officedocument.presentationml.presentation',
            ],
        ];

        if ($request->hasFile('file')) {

            $imagePath  = null;

            $file       = $request->file('file');
            $fileType   = $file->getMimeType();
            $fileSize   = $file->getSize();
            $originalFileName = $file->getClientOriginalName();

            $imagePath =  $this->uploadImage($request, 'file', 'media-manager');

            $image  = array(
                'status'    => $imagePath == null ? false : true,
                'type'      => $fileType,
                'size'      => $fileSize,
                'path'      => $imagePath,
                'original_name' => $originalFileName
            );
        }

        if (isset($request->quick_reply)) {
            $image  = array(
                'status'    => true,
                'type'      => $request->file_type,
                'size'      => $request->file_size,
                'path'      => $request->file_path
            );
        }

        if ($image['type']) {
            foreach ($typeMap as $key => $mimeTypes) {
                if (in_array($image['type'], $mimeTypes)) {
                    $messageType = $key;
                    break;
                }
            }
        }

        // Tambahkan data reply jika ada
        $replyData = [
            'reply_to' => $request->input('reply_to'),
            'reply_text' => $request->input('reply_text')
        ];

        $setting     = Setting::first(['signature_option', 'signature_text']);
        $textMessage = $request->message ?? '';
        $signature   = ''; // default kosong

        switch ($setting->signature_option) {
            case 'by_login':
                $signature = my_user()->name;
                break;

            case 'by_device':
                if ($history->from === 'whatsapp') {
                    $signature = $history->device->name ?? '';
                } elseif ($history->from === 'waba') {
                    $signature = $history->waba->meta->name ?? '';
                } elseif ($history->from === 'livechat') {
                    $signature = $history->livechat->name ?? '';
                }
                break;

            case 'custom':
                $signature = $setting->signature_text;
                break;
        }

        // Tambahkan signature jika ada isinya
        if (!empty($signature)) {
            $textMessage .= "\n\n" . $signature;
        }


        $message = $this->historyChatObserver->sendMessage($history, $textMessage, 'device', $image, $replyData);


        if ($history->from == 'whatsapp') {

            $details = null;
            if ($request->input('reply_to') != null) {
                $details = HistoryChatDetail::where('id', $request->input('reply_to'))
                    ->first(['messageid', 'remotejid']);
            }

            $responseData = $this->whatsappServiceObserver->sendMessage(($history->metadata ?? $history->from_number), $history->device_id, $message->message, ($image['path'] != null ? asset($image['path']) : ''), $messageType, null, false, $details);

            if ($responseData['status'] == 200) {
                $message->update([
                    'messageid'         => $responseData['data']['key']['id'],
                    'remotejid'         => $responseData['data']['key']['remoteJid'],
                    'quoted_message'    => $responseData['data'],
                ]);
            }
        }

        if ($history->from == 'waba') {

            $config                                 = $history->waba->meta_data;
            $config                                 = $config ? json_decode($config, true) : [];
            $messageVariable['appid']               = $config['whatsapp']['app_id'] ?? null;
            $messageVariable['phoneid']             = $config['whatsapp']['phone_number_id'] ?? null;
            $messageVariable['wabaid']              = $config['whatsapp']['waba_id'] ?? null;
            $messageVariable['access_token']        = $config['whatsapp']['access_token'] ?? null;

            if ($image['status'] == true) {
                $sendMedia                              = $this->whatsappOfficialServiceObserver->uploadMedia($messageVariable['access_token'], asset($message->file_path), $messageType, $messageVariable['phoneid']);

                if ($sendMedia != null) {
                    $sendMessage    = $this->whatsappOfficialServiceObserver->sendMediaMessage($history->store->phone, $messageType, $sendMedia, $message->message, ($image['original_name'] ?? basename($message->file_path)), $messageVariable);
                    if ($sendMessage['status'] == 200) {
                        $message->update([
                            'messageid'     => $sendMessage['messageid']
                        ]);
                    }
                }
            } else {

                $sendMessage    = $this->whatsappOfficialServiceObserver->sendTextMessage($history->from_number, $message->message, $messageVariable);

                if ($sendMessage['status'] == 200) {
                    $message->update([
                        'messageid'     => $sendMessage['messageid']
                    ]);
                }
            }
        }

        if ($history->from == 'telegram') {

            $details = null;
            if ($request->input('reply_to') != null) {
                $details = HistoryChatDetail::where('id', $request->input('reply_to'))
                    ->first(['messageid', 'remotejid']);
            }

            $responseData = $this->telegramService->sendMessage($history->telegram, $history->from_number, $message->message, ($image['path'] != null ? asset($image['path']) : ''), $details);

            if ($responseData->status() == 200) {
                $responseData   = json_decode($responseData->body());
                $message->update([
                    'messageid'         => $responseData->result->message_id
                ]);
            }
        }

        if ($history->from == 'instagram') {
            $instagram = $history->instagram;

            if ($image['status'] == true && !empty($message->message)) {

                $mediaResponse = $this->instagramService->sendMessage(
                    $instagram,
                    'file',
                    $history->from_number,
                    '',
                    asset($message->file_path),
                    $messageType
                );



                if (!empty($message->message)) {
                    usleep(500000); // 0.5 detik

                    $textResponse = $this->instagramService->sendMessage(
                        $instagram,
                        'text',
                        $history->from_number,
                        $message->message,
                        null,
                        null
                    );
                }
            } elseif ($image['status'] == true) {
                $mediaResponse = $this->instagramService->sendMessage(
                    $instagram,
                    'file',
                    $history->from_number,
                    '',
                    asset($message->file_path),
                    $messageType
                );
            } else {
                $textResponse = $this->instagramService->sendMessage(
                    $instagram,
                    'text',
                    $history->from_number,
                    $message->message,
                    null,
                    null
                );
            }
        }

        if ($history->from == 'messanger') {
            $messenger = $history->messenger;

            if ($image['status'] == true && !empty($message->message)) {

                $mediaResponse = $this->messengerService->sendMessage(
                    $messenger,
                    'file',
                    $history->from_number,
                    '',
                    asset($message->file_path),
                    $messageType
                );

                // if ($mediaResponse->successful()) {
                //     $responseData = $mediaResponse->json();
                //     $message->update(['messageid' => $responseData['message_id'] ?? null]);
                // }

                if (!empty($message->message)) {
                    usleep(500000); // 0.5 detik

                    $textResponse = $this->messengerService->sendMessage(
                        $messenger,
                        'text',
                        $history->from_number,
                        $message->message,
                        null,
                        null
                    );

                    // if ($textResponse->successful()) {
                    //     $textResponseData = $textResponse->json();

                    // }
                }
            } elseif ($image['status'] == true) {
                $mediaResponse = $this->messengerService->sendMessage(
                    $messenger,
                    'file',
                    $history->from_number,
                    '',
                    asset($message->file_path),
                    $messageType
                );

                // if ($mediaResponse->successful()) {
                //     $responseData = $mediaResponse->json();
                //     $message->update(['messageid' => $responseData['message_id'] ?? null]);
                // }
            }
            // Jika hanya text tanpa media
            else {
                $textResponse = $this->messengerService->sendMessage(
                    $messenger,
                    'text',
                    $history->from_number,
                    $message->message,
                    null,
                    null
                );

                // if ($textResponse->successful()) {
                //     $responseData = $textResponse->json();
                //     $message->update(['messageid' => $responseData['message_id'] ?? null]);
                // }
            }
        }

        return response()->json(HistoryChatResources::make($message), 200);
    }

    public function deleteMessage(HistoryChatDetail $detail)
    {
        $detail->delete();

        return response()->json([
            'status'     => true,
        ], 200);
    }

    public function labels(Request $request)
    {
        $labels  = $this->labelObserver->getData($request)->where(function ($q) use ($request) {
            return $request->type ? $q->where('type', $request->type) : $q->where('type', 'keyword');
        })->where(function ($q) use ($request) {
            return $request->pipeline_id ? $q->where('pipeline_segment_id', $request->pipeline_id) : '';
        })->get(['id', 'name']);
        return response()->json([
            'labels'     => $labels,
        ], 200);
    }

    public function updatePipeLineAndLabel(Request $request, HistoryChat $history)
    {

        if ($history->store) {
            $history->store->update([
                'label_id'      => $request->label
            ]);
        }
    }

    public function categories(Request $request)
    {
        $categories  = $this->categoryObserver->getData($request)->get(['id', 'name']);
        return response()->json([
            'categories'    => $categories,
        ], 200);
    }

    public function changeForLabels(Request $request, HistoryChat $history)
    {
        $history->update([
            'label' => !empty($request->labels) ? json_encode($request->labels) : json_encode([])
        ]);

        if ($history->store) {
            $firstLabel = $request->labels[0] ?? null;

            $history->store->update([
                'label_id' => is_array($firstLabel) ? ($firstLabel['id'] ?? null) : $firstLabel
            ]);
        }

        return response()->json([
            'status' => true,
        ], 200);
    }

    public function changeForCategory(Request $request, HistoryChat $history)
    {
        if ($history->store) {
            $history->store->update([
                'category_id'       => $request->category['id']
            ]);
        }

        return response()->json([
            'status'     => true,
        ], 200);
    }

    public function changeForHandled(Request $request, HistoryChat $history)
    {
        $history->update([
            'assigned_by'       => my_user()->id,
            'assignment_at'     => now(),
            'handled_by'        => $request->handled['id']
        ]);

        return response()->json([
            'detail'        => array(
                'assignment_by'     => $history->assignmentby->name ?? '',
                'assignment_at'     => $history->assignment_at != null ? $history->assignment_at->format('Y-m-d H:i') : '',
            ),
            'status'        => true,
        ], 200);
    }

    public function changeCalobolator(Request $request, HistoryChat $history)
    {

        $history->update([
            'collabolator'                => !empty($request->collabolator) ? json_encode($request->collabolator) : json_encode([])
        ]);

        return response()->json([
            'status'     => true,
        ], 200);
    }

    public function changeAddional(Request $request, HistoryChat $history)
    {
        $history->update([
            'additional_data'   => !empty($request->additional_data) ? json_encode($request->additional_data) : json_encode([]),
            'note'              => $request->note
        ]);

        return response()->json([
            'status'     => true,
        ], 200);
    }

    public function blockAndUnblock(Request $request, HistoryChat $history)
    {
        $history->update([
            'status'    => $request->status
        ]);

        return response()->json([
            'status'     => true,
        ], 200);
    }

    public function resolvedChange(Request $request, HistoryChat $history)
    {
        $history->update([
            'status'            => $request->status,
            'resolved_at'       => now(),
            'resolved_by_id'    => my_user()->id,
            'takeover'          => 'no'
        ]);

        return response()->json([
            'detail'        => array(
                'resolved_by'       => $history->resolved->name ?? '',
                'resolved_at'       => $history->resolved_at != null ? $history->resolved_at->format('Y-m-d H:i') : '',
            ),
            'status'        => true,
        ], 200);
    }

    public function updateHistoryChatRead(HistoryChat $history)
    {
        HistoryChatDetail::where('is_read', 'no')->where('history_chat_id', $history->id)->update([
            'is_read'   => 'yes'
        ]);

        // FIX: Reset unread_count saat agent buka/baca chat
        $history->update(['unread_count' => 0]);

        // Invalidate cache CRM contacts saat agent buka/baca chat
        try {
            $prefix = config('cache.prefix', 'replai_automation_cache');
            $pattern = $prefix . '_crm_contacts_' . $history->merchant_id . '_%';
            \DB::table('cache')->where('key', 'like', $pattern)->delete();
        } catch (\Exception $e) {}

        return response()->json([
            'status'    => true,
            'messages'  => 'success',
        ], 200);
    }

    public function deleteChats(HistoryChat $history)
    {
        try {

            DB::beginTransaction();
            $history->delete();
            DB::commit();

            return response()->json([
                'status'        => false,
                'message'       => 'Berhasil menghapus pesan',
            ], 200);
        } catch (\Exception $e) {
            DB::rollBack();
            return redirect()->back()->with(['gagal' => $e->getMessage()]);
        }
    }

    public function getDevices(Request $request)
    {

        $data   = [];

        if ($request->type == 'livechat') {
            $data   = $this->livechatObserver->getData($request)->get(['id', 'name']);
        }

        if ($request->type == 'telegram') {
            $data   = $this->telegramService->getData($request)->get(['id', 'name']);
        }

        if ($request->type == 'waba') {
            $data   = $this->wabaDeviceObserver->getData($request)->get(['id', 'phone']);
        }

        if ($request->type == 'whatsapp') {
            $data   = $this->whatsappDeviceObserver->getData($request)->get(['id', 'name']);
        }

        return response()->json([
            'status'        => false,
            'data'          => $data,
        ], 200);
    }

    public function changeDevices(Request $request, HistoryChat $history)
    {
        $history->update([
            'from'      => $request->type,
            'device_id'         => $request->from == 'whatsapp' ? $request->device : null,
            'whatsapp_waba_id'  => $request->from == 'waba' ? $request->device : null,
            'livechat_id'       => $request->from == 'livechat' ? $request->device : null,
            'telegram_id'       => $request->from == 'telegram' ? $request->device : null
        ]);

        return response()->json([
            'status'     => true,
        ], 200);
    }

    /**
     * Get WABA templates for a chat
     */
    public function getTemplates(Request $request, HistoryChat $history)
    {
        \Log::info('getTemplates called', [
            'history_id' => $history->id,
            'from' => $history->from,
            'whatsapp_waba_id' => $history->whatsapp_waba_id,
        ]);

        $wabaId = $history->whatsapp_waba_id;

        if (!$wabaId) {
            \Log::info('getTemplates: No WABA ID');
            return response()->json(['data' => [], 'message' => 'No WABA account linked'], 200);
        }

        $waba = \App\Models\WhatsappKeyAccount::withoutGlobalScopes()->find($wabaId);
        if (!$waba) {
            \Log::info('getTemplates: WABA not found for ID: ' . $wabaId);
            return response()->json(['data' => [], 'message' => 'WABA not found'], 200);
        }

        \Log::info('getTemplates: WABA found', [
            'waba_id' => $waba->id,
            'meta_account_id' => $waba->meta_account_id,
        ]);

        // Get meta_account_id from WABA device
        $metaAccountId = $waba->meta_account_id;
        if (!$metaAccountId) {
            \Log::info('getTemplates: No meta_account_id');
            return response()->json(['data' => [], 'message' => 'No Meta account linked'], 200);
        }

        $search = $request->input('search', '');

        $templates = MessageTemplate::where('meta_account_id', $metaAccountId)
            ->where('for_waba', 'yes')
            ->where('waba_status_template', 'APPROVED')
            ->when($search, function ($q) use ($search) {
                $q->where('name', 'like', "%{$search}%");
            })
            ->orderBy('name')
            ->limit(50)
            ->get(['id', 'name', 'message', 'media_type', 'category', 'lang', 'image']);

        $result = $templates->map(function ($t) {
            $meta = json_decode($t->message, true);
            $components = $meta['components'] ?? [];

            $headerType = null;
            $headerText = null;
            $bodyText = null;
            $bodyParams = 0;
            $footerText = null;
            $buttons = [];

            foreach ($components as $comp) {
                $type = $comp['type'] ?? '';
                if ($type === 'HEADER') {
                    $headerType = strtolower($comp['format'] ?? 'text');
                    if ($headerType === 'text') {
                        $headerText = $comp['text'] ?? '';
                    }
                }
                if ($type === 'BODY') {
                    $bodyText = $comp['text'] ?? '';
                    preg_match_all('/\{\{(\d+)\}\}/', $bodyText, $matches);
                    $bodyParams = count($matches[1] ?? []);
                }
                if ($type === 'FOOTER') {
                    $footerText = $comp['text'] ?? '';
                }
                if ($type === 'BUTTONS') {
                    $buttons = $comp['buttons'] ?? [];
                }
            }

            return [
                'id'            => $t->id,
                'name'          => $t->name,
                'category'      => $t->category,
                'lang'          => $t->lang,
                'media_type'    => $t->media_type,
                'header_type'   => $headerType,
                'header_text'   => $headerText,
                'body_text'     => $bodyText,
                'body_params'   => $bodyParams,
                'footer_text'   => $footerText,
                'buttons'       => $buttons,
                'image'         => $t->image ? asset($t->image) : null,
            ];
        });

        return response()->json(['data' => $result], 200);
    }

    /**
     * Send WABA template message
     */
    public function sendTemplate(Request $request, HistoryChat $history)
    {
        $request->validate([
            'template_id'   => 'required|exists:message_templates,id',
            'parameters'    => 'nullable|array',
        ]);

        $template = MessageTemplate::withoutGlobalScopes()->findOrFail($request->template_id);
        $meta = json_decode($template->message, true);
        $components = $meta['components'] ?? [];

        $store = $history->store;
        if (!$store) {
            return response()->json(['error' => 'Store not found'], 400);
        }

        // Get WABA config (same approach as sendMessage)
        $wabaDevice = \App\Models\WhatsappKeyAccount::withoutGlobalScopes()->find($history->whatsapp_waba_id);
        if (!$wabaDevice) {
            return response()->json(['error' => 'WABA device not found'], 400);
        }

        $config = json_decode($wabaDevice->meta_data ?? '{}', true);
        $accessToken = $config['whatsapp']['access_token'] ?? null;
        $phoneId     = $config['whatsapp']['phone_number_id'] ?? null;

        if (!$accessToken || !$phoneId) {
            return response()->json(['error' => 'WABA config incomplete'], 400);
        }

        $variablesData = [
            'phoneid'      => $phoneId,
            'access_token' => $accessToken,
        ];

        // Build template content for Meta API
        $parameters = $request->input('parameters', []);
        $templateContent = [
            'name'       => $template->name,
            'language'   => ['code' => $template->lang ?? 'id'],
            'components' => []
        ];

        // Header with media
        $savedMediaPath = null;
        $savedMediaType = null;
        $savedMediaSize = null;
        $savedOriginalName = null;

        foreach ($components as $comp) {
            if (($comp['type'] ?? '') === 'HEADER' && isset($comp['format'])) {
                $format = strtolower($comp['format']);
                if (in_array($format, ['image', 'video', 'document'])) {
                    if ($request->hasFile('header_media')) {
                        $mediaPath = $this->uploadImage($request, 'header_media', 'media-manager');

                        // Save media info for CRM display
                        $savedMediaPath = $mediaPath;
                        $savedMediaType = $request->file('header_media')->getMimeType();
                        $savedMediaSize = $request->file('header_media')->getSize();
                        $savedOriginalName = $request->file('header_media')->getClientOriginalName();

                        // Get proper mime type
                        $mimeTypes = [
                            'image' => 'image/jpeg',
                            'video' => 'video/mp4',
                            'document' => 'application/pdf',
                        ];
                        $mime = $mimeTypes[$format] ?? 'application/octet-stream';

                        // uploadMedia(accessToken, fileUrl, mimeType, phoneId)
                        $mediaId = $this->whatsappOfficialServiceObserver->uploadMedia(
                            $accessToken, asset($mediaPath), $mime, $phoneId
                        );

                        if ($mediaId) {
                            $templateContent['components'][] = [
                                'type'       => 'header',
                                'parameters' => [[
                                    'type'  => $format,
                                    $format => ['id' => $mediaId]
                                ]]
                            ];
                        }
                    }
                }
            }
        }

        // Body parameters
        if (!empty($parameters)) {
            $bodyParams = [];
            foreach ($parameters as $param) {
                $bodyParams[] = [
                    'type' => 'text',
                    'text' => $param
                ];
            }
            $templateContent['components'][] = [
                'type'       => 'body',
                'parameters' => $bodyParams
            ];
        }

        // Send via existing observer method
        $response = $this->whatsappOfficialServiceObserver->sendTemplateMessage(
            $store, $templateContent, $variablesData
        );

        if (isset($response['status']) && $response['status'] == 200) {
            // Build full template message with all components
            $messageParts = [];
            $headerText = '';
            $bodyText = '';
            $footerText = '';
            $buttons = [];

            foreach ($components as $comp) {
                $type = $comp['type'] ?? '';
                if ($type === 'HEADER') {
                    $format = strtolower($comp['format'] ?? 'text');
                    if ($format === 'text') {
                        $headerText = $comp['text'] ?? '';
                    } elseif (in_array($format, ['image', 'video', 'document'])) {
                        // Don't add text label - media will be displayed directly
                        $headerText = '';
                    }
                }
                if ($type === 'BODY') {
                    $bodyText = $comp['text'] ?? '';
                }
                if ($type === 'FOOTER') {
                    $footerText = $comp['text'] ?? '';
                }
                if ($type === 'BUTTONS') {
                    $buttons = $comp['buttons'] ?? [];
                }
            }

            // Replace parameters in body
            if (!empty($parameters)) {
                foreach ($parameters as $i => $param) {
                    $bodyText = str_replace('{{' . ($i + 1) . '}}', $param, $bodyText);
                }
            }

            // Build complete message
            if ($headerText) {
                $messageParts[] = $headerText;
            }
            $messageParts[] = $bodyText;
            if ($footerText) {
                $messageParts[] = $footerText;
            }
            if (!empty($buttons)) {
                $btnTexts = [];
                foreach ($buttons as $btn) {
                    $btnTexts[] = '🔘 ' . ($btn['text'] ?? '');
                }
                $messageParts[] = implode("\n", $btnTexts);
            }

            $fullMessage = implode("\n\n", array_filter($messageParts));

            // Prepare media data for CRM display
            $imageData = null;
            if ($savedMediaPath) {
                $imageData = [
                    'path' => $savedMediaPath,
                    'type' => $savedMediaType,
                    'size' => $savedMediaSize,
                    'original_name' => $savedOriginalName,
                ];
            }

            $message = $this->historyChatObserver->sendMessage(
                $history, $fullMessage, 'device', $imageData, []
            );
            if ($response['messageid'] ?? null) {
                $message->update(['messageid' => $response['messageid']]);
            }

            return response()->json([
                'status'    => 200,
                'messageid' => $response['messageid'] ?? null,
                'message'   => 'Template sent successfully'
            ], 200);
        }

        return response()->json([
            'status'  => 500,
            'error'   => $response['message'] ?? 'Failed to send template',
        ], 500);
    }

}
