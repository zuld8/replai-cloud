    /**
     * Upload a sample file to Meta Resumable Upload API.
     * Always does a fresh upload - handles are NOT cached because they expire 
     * and are tied to the uploading user/token.
     */
    private function getOrUploadSampleHandle(string $type, $meta): ?string
    {
        // Sample file paths
        $samplePaths = [
            'image'    => public_path('assets/samples/sample-header.jpg'),
            'video'    => public_path('assets/samples/sample-header.mp4'),
            'document' => public_path('assets/samples/sample-header.pdf'),
        ];
        $mimeTypes = [
            'image'    => 'image/jpeg',
            'video'    => 'video/mp4',
            'document' => 'application/pdf',
        ];

        $filePath = $samplePaths[$type] ?? $samplePaths['image'];
        $mimeType = $mimeTypes[$type]  ?? $mimeTypes['image'];

        if (!file_exists($filePath)) {
            \Log::warning("Sample file not found: {$filePath}");
            return null;
        }

        try {
            $fileContent = file_get_contents($filePath);
            $fileLength  = strlen($fileContent);
            $apiVersion  = config('custom.api_waba_version');

            // FIX: Selalu gunakan platform fb_app_id untuk sample upload.
            // User app_id mungkin tidak punya permission Resumable Upload API.
            // Token ($meta->access_token) tetap milik user.
            $platformSetting = \App\Models\InternalSetting::first(['fb_app_id']);
            $uploadAppId = ($platformSetting && $platformSetting->fb_app_id)
                ? $platformSetting->fb_app_id
                : $meta->app_id;

            \Log::info('Uploading sample media to Meta', [
                'type'        => $type,
                'upload_app'  => $uploadAppId,
                'meta_app_id' => $meta->app_id,
                'file_size'   => $fileLength,
            ]);

            // Step 1: Initiate upload session
            $sessionResp = Http::withHeaders([
                'Authorization' => 'Bearer ' . $meta->access_token,
            ])->post("https://graph.facebook.com/{$apiVersion}/{$uploadAppId}/uploads", [
                'file_length' => $fileLength,
                'file_type'   => $mimeType,
            ]);

            if ($sessionResp->status() !== 200) {
                \Log::warning('Meta sample upload session failed', [
                    'resp'       => $sessionResp->json(),
                    'upload_app' => $uploadAppId,
                ]);
                return null;
            }

            $uploadId = $sessionResp->json()['id'];

            // Step 2: Upload file bytes
            $uploadResp = Http::withHeaders([
                'Authorization' => 'OAuth ' . $meta->access_token,
                'file_offset'   => '0',
                'Content-Type'  => $mimeType,
            ])->withBody($fileContent, $mimeType)
              ->post("https://graph.facebook.com/{$apiVersion}/{$uploadId}");

            if ($uploadResp->status() !== 200) {
                \Log::warning('Meta sample file upload failed', ['resp' => $uploadResp->json()]);
                return null;
            }

            $handle = $uploadResp->json()['h'] ?? null;
            if (!$handle) return null;

            \Log::info("Fresh media handle obtained", [
                'type' => $type, 
                'handle_prefix' => substr($handle, 0, 30),
            ]);

            return $handle;

        } catch (\Exception $e) {
            \Log::error('getOrUploadSampleHandle error: ' . $e->getMessage());
            return null;
        }
    }

        function initiateResumableUploadSession($file, $accessToken, $appId)
    {
        $sessionResponse = $this->createResumableUploadSession($file, $accessToken, $appId);
        // DEBUG LOG
        \Log::info('WABA Upload Debug', [
            'step' => 'create_session',
            'success' => $sessionResponse->success,
            'data' => $sessionResponse->data,
            'app_id' => $appId,
        ]);

        if (!$sessionResponse->success) {
            return $sessionResponse->data;
        }

        $uploadSessionId    = $sessionResponse->data;
        $fileName           = $file->getPathname();
        $url                = "https://graph.facebook.com/{$uploadSessionId}";

        $responseObject = new \stdClass();

        $fileContents = file_get_contents($fileName);
        $fileMimeType = $file->getMimeType() ?? 'application/octet-stream';

        $response = Http::withHeaders([
            'Authorization'  => 'OAuth ' . $accessToken,
            'file_offset'    => '0',
            'Content-Type'   => $fileMimeType,
        ])->withBody($fileContents, $fileMimeType)->post($url);

        if ($response->status() == 200) {
            $responseObject->success    = true;
            $responseObject->data = $response->json()['h'] ?? null;
        } else {
            $responseObject->success    = false;
            $json = $response->json();
            $responseObject->data = $json['debug_info']['message'] 
                ?? $json['error']['message'] 
                ?? $json['message'] 
                ?? 'Upload failed with status: ' . $response->status();
        }

        return $responseObject;
    }

    function createResumableUploadSession($file, $accessToken, $appId)
    {

        $fileLength     = $file->getSize();
        $fileType       = $file->getMimeType();
        $url            = "https://graph.facebook.com/" . config('custom.api_waba_version') . "/{$appId}/uploads";

        $responseObject = new \stdClass();

        $response   = Http::withHeaders([
            'Authorization' => "OAuth " . $accessToken,
            'file_offset' => 0,
        ])->withOptions([
            'query' => [
                'file_length'       => $fileLength,
                'file_type'         => $fileType,
                'access_token'      => $accessToken,
            ],
        ])->post($url);

        if ($response->status() == 200) {
            $responseObject->success    = true;
            $responseObject->data = $response->json()['id'] ?? null;
        } else {
            $responseObject->success    = false;
            $json = $response->json();
            $responseObject->data = $json['error']['message'] 
                ?? $json['debug_info']['message'] 
                ?? $json['message'] 
                ?? 'Session creation failed with status: ' . $response->status();
        }


        return $responseObject;
    }

    public function deleteTemplate(MessageTemplate $template, MetaAccount $meta)
    {
 

        $url = "https://graph.facebook.com/" . config('custom.api_waba_version') . "/{$meta->business_app}/message_templates";



        $requestData['hsm_id']  = $template->meta_id;
        $requestData['name']    = strtolower(preg_replace("/[^0-9a-zA-Z]/", "_", $template->name));

        $responseObject = $this->sendHttpRequest('DELETE', $url, $requestData, $meta->access_token);

        if ($responseObject->success) {
            $template->delete();
        }

        return $responseObject;
    }


    private function sendHttpRequest($method, $url, $data = [], $accessToken)
    {
        $responseObject = new \stdClass();

        // Tentukan metode HTTP yang didukung
        $httpClient = Http::withHeaders([
            'Authorization' => 'Bearer ' . $accessToken,
            'Content-Type' => 'application/json',
        ]);

        // Cek metode HTTP untuk menambahkan data jika perlu
        if (isset($data) && in_array($method, ['POST', 'PUT', 'DELETE'])) {
            $response = $httpClient->$method($url, $data);
        } else {
            $response = $httpClient->get($url);
        }

        if ($response->status() != 200) {
            $responseObject->success    = false;
            $responseObject->error      = $response->status();
            $responseObject->message    = $response->json()['error']['message'];
        } else {
            $responseObject->success = true;
            $responseObject->data = $response->json();
        }


        return $responseObject;
    }


    public function buildTemplate(BlashWhatsapp $campaign)
    {

        $templateDetails                = json_decode($campaign->metadata, true) ?? [];
        $template['name']               = strtolower(preg_replace("/[^0-9a-zA-Z]/", "_", $campaign->template->name ?? '-'));
        $template['language']['code']   = $campaign->template->lang ?? '';
        $template['components']         = [];

        if (!empty($templateDetails['header']) && (!empty($templateDetails['header']['parameters']) || $campaign->file != null)) {
            $headerComponent            = $this->buildHeaderComponent($templateDetails, ($campaign->file != null ? asset($campaign->file) : ''));
            // $headerComponent            = $this->buildHeaderComponent($templateDetails, ($campaign->file != null ? 'https://mdigitalhub.sirv.com/PasarSafe/vectors/stock-manager.png' : ''));
            $template['components'][]   = $headerComponent;
        }

        if (!empty($templateDetails['body']) && isset($templateDetails['body']['parameters'])) {
            $bodyComponent = $this->buildBodyComponent($templateDetails);
            $template['components'][] = $bodyComponent;
        }

        if (!empty($templateDetails['buttons'])) {
            $buttonComponents = $this->buildButtonComponent($templateDetails);
            foreach ($buttonComponents as $buttonComponent) {
                $template['components'][] = $buttonComponent;
            }
        }

        //dd($template);
        return $template;
    }

    public function buildTemplateChatbot(ChatBot $campaign)
    {

        $templateDetails                = json_decode($campaign->metadata, true);
        $template['name']               = strtolower(preg_replace("/[^0-9a-zA-Z]/", "_", $campaign->template->name ?? '-'));
        $template['language']['code']   = $campaign->template->lang ?? '';
