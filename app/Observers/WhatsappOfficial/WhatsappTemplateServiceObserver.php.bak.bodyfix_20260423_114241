    public function createData(Request $request, MetaAccount $meta)
    {
        
        $url = "https://graph.facebook.com/" . config('custom.api_waba_version') . "/{$meta->business_app}/message_templates";

        $requestData = [
            "name"          => strtolower(preg_replace("/[^0-9a-zA-Z]/", "_", $request->name)),
            "language"      => $request->lang,
            "category"      => $request->category,
        ];
        // storedData will be built at the end after all components are ready

        if ($request->type == 'text' && $request->header_text != null) {
            $headerComponent = [];
            $headerComponent['type']        = "HEADER";
            $headerComponent['format']      = strtoupper($request->type);
            $headerComponent['text']        = $request->header_text;
            $requestData['components'][]    = $headerComponent;
        }

        if ($request->type != 'text') {
            if ($request->has('files') && $request->file('files') !== null) {
                // File uploaded - use resumable upload
                $fileUploadResponse = $this->initiateResumableUploadSession($request->file('files'), $meta->access_token, $meta->app_id);

                if (!$fileUploadResponse->success) {
                    return array(
                        'status'        => false,
                        'message'       => $fileUploadResponse->data
                    );
                }

                $requestData['components'][] = [
                    "type"      => "HEADER",
                    "format"    => strtoupper($request->type),
                    "example"   => [
                        "header_handle" => [
                            $fileUploadResponse->data
                        ]
                    ]
                ];
            } else {
                // No file uploaded - auto pre-upload sample file to Meta and cache handle
                $handle = $this->getOrUploadSampleHandle($request->type, $meta);
                if ($handle) {
                    $requestData['components'][] = [
                        "type"      => "HEADER",
                        "format"    => strtoupper($request->type),
                        "example"   => [
                            "header_handle" => [$handle]
                        ]
                    ];
                }
                // If upload failed, return error instead of silently skipping header
                if (!$handle) {
                    return array(
                        'status'  => false,
                        'message' => 'Gagal upload sample ' . $request->type . ' ke Meta. Pastikan file sample valid dan app_id sudah diset.'
                    );
                }
            }
        }

        if ($request->body_message != null) {
            $bodyComponent = [];

            $bodyComponent['type'] = "BODY";
            $bodyComponent['text'] = str_replace("\r\n", "\n", $request->body_message);

            if (isset($request->variables)) {
                if (count($request->variables) > 0) {
                    $variablesSamples = array_map(function ($variable) {
                        $decodedVariable = json_decode($variable, true); // Decode JSON ke array
                        return $decodedVariable['sample'] ?? null; // Ambil 'sample' jika ada
                    }, $request->variables);
                    $bodyComponent['example']['body_text'][] = $variablesSamples;
                }
            }


            $requestData['components'][] = $bodyComponent;
        }

        if ($request->footer_message != null && $request->footer_message != '') {
            $requestData['components'][] = [
                "type" => "FOOTER",
                "text" => $request->footer_message
            ];
        }

        if ($request->has('buttons')) {
            if (!isset($requestData['components'])) {
                $requestData['components'] = [];
            }

            $requestData['components'][] = [
                'type'      => 'BUTTONS',
                'buttons'   => []
            ];

            $quickReplyButtons = [];

            foreach ($request->buttons as $button) {
                $button     = json_decode($button, true);
                if ($button['type'] === 'custom') {
                    $quickReplyButtons[] = [
                        'type' => 'QUICK_REPLY',
                        'text' => $button['button_name'],
                    ];
                }
            }

            if (isset($request->buttons)) {
                foreach ($request->buttons as $button) {
                    $button     = json_decode($button, true);
                    if ($button['type'] !== 'custom') {
                        if ($button['type'] === 'web') {
                            $requestData['components'][count($requestData['components']) - 1]['buttons'][] = [
                                'type'  => 'URL',
                                'text'  => $button['button_name'],
                                'url'   => $button['button_link'],
                            ];
                        } elseif ($button['type'] === 'call') {
                            $requestData['components'][count($requestData['components']) - 1]['buttons'][] = [
                                'type'          => 'PHONE_NUMBER',
                                'text'          => $button['button_name'],
                                'phone_number'  => $button['country'] . $button['phone'],
                            ];
                        } elseif ($button['type'] === 'copy') {
                            if ($request->category == 'CATEGORY') {
                                $requestData['components'][count($requestData['components']) - 1]['buttons'][] = [
                                    'type'      => 'COPY_CODE',
                                    'example'   => $button['text'],
                                ];
                            }
                        }
                    }
                }
            }

            // Add the quick reply buttons at the start
            if (!empty($quickReplyButtons)) {
                $requestData['components'][count($requestData['components']) - 1]['buttons'] = array_merge($quickReplyButtons, $requestData['components'][count($requestData['components']) - 1]['buttons']);
            }
        }

        $responseObject = new \stdClass();

        \Log::info('WABA Template Create Request', [
            'url' => $url,
            'data' => $requestData,
        ]);

        $response = Http::withHeaders([
            'Authorization' => 'Bearer ' . $meta->access_token,
            'Content-Type' => 'application/json',
        ])->post($url, $requestData);

        \Log::info('WABA Template Create Response', [
            'status' => $response->status(),
            'body' => $response->json(),
        ]);

        if ($response->status() != 200) {
            $errorJson  = $response->json();
            $message    = $errorJson['error']['error_user_title']
                       ?? $errorJson['error']['message']
                       ?? $errorJson['error']['error_user_msg']
                       ?? 'Terjadi kesalahan, silahkan ulangi';
            return array(
                'status'        => false,
                'message'       => $message
            );
        }

        $responseObject->success    = true;
        $responseData               = $response->json();
        $responseObject->data       = (object) $responseData;

        // Build storedData = requestData + HEADER type for local reference
        // Meta skips HEADER when no file, but we must store it for UI accuracy
        $storedData = $requestData;
        if ($request->type != 'text') {
            $hasHeader = false;
            foreach ($storedData['components'] ?? [] as $comp) {
                if (($comp['type'] ?? '') === 'HEADER') { $hasHeader = true; break; }
            }
            if (!$hasHeader) {
                array_unshift($storedData['components'], [
                    'type'   => 'HEADER',
                    'format' => strtoupper($request->type),
                ]);
            }
        }

        MessageTemplate::create([
            'meta_account_id'       => $meta->id,
            'name'                  => $request->name,
            'category'              => $request->category,
            'lang'                  => $request->lang,
            'type_content'          => 'description',
            'type'                  => 'whatsapp',
            'meta_id'               => $responseObject->data->id,
            'for_waba'              => 'yes',
            'message'               => json_encode($storedData),
            'waba_status_template'  => $responseObject->data->status,
            'created_by'            => my_user()->id,
        ]);

        return array(
            'status'        => true,
            'message'       => 'Berhasil'
        );
    }

